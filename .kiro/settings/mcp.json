{
  "mcpServers": {
    "browsermcp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @browsermcp/mcp@latest"
      ],
      "disabled": false,
      "autoApprove": []
    },
    "browser-tools": {
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @agentdeskai/browser-tools-mcp@latest"
      ],
      "disabled": false,
      "autoApprove": [
        "takeScreenshot"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}